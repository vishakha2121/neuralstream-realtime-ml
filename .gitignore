# Data files
*.csv
*.xlsx
*.xls
*.json
!package.json
!package-lock.json
*.xml
*.parquet
*.arrow
*.feather

# Reports
*.pdf
*.html
!frontend/public/index.html
*.docx
*.pptx

# Archives
*.zip
*.tar
*.gz
*.rar
*.7z
*.bz2

# ============================================
# Testing & Coverage
# ============================================
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
.tox/
.nosetests.xml
.jest/
.eslintcache
.stylelintcache
.testresults/
test-results/
cypress/videos/
cypress/screenshots/

# ============================================
# Dependency directories
# ============================================
jspm_packages/
web_modules/
.parcel-cache/
.stencil/

# ============================================
# System
# ============================================
*.pid
*.seed
*.pid.lock
*.lock
!package-lock.json
!yarn.lock
"@ | Out-File -FilePath .gitignore -Encoding UTF8

