*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~
.*.swp

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock

# ============================================
# OS Generated Files
# ============================================
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
ehthumbs.db
*.swp
*.swo

# Linux
*~
.directory
.directory-*
.dmrc
.gnupg/
.gnome/
.gvfs/
.pid
.svn/
.Trash-*
.cache/
.config/
.local/
.nfs*

# ============================================
# Frontend (React / Node.js)
# ============================================
# Dependencies
node_modules/
.pnpm-store/
.npm/
.yarn/
.yarn-cache/
.yarn-integrity
.yarn-offline-mirror/

# Build outputs
frontend/build/
frontend/dist/
frontend/out/
frontend/.next/
frontend/.nuxt/
frontend/.cache/
frontend/*.tsbuildinfo

# Testing
frontend/coverage/
frontend/.nyc_output/

# Environment files
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local
frontend/.env.staging.local

# Misc
frontend/.eslintcache
frontend/.stylelintcache
frontend/.prettiercache
frontend/package-lock.json
frontend/yarn.lock
frontend/pnpm-lock.yaml

# ============================================
# Backend (Python / FastAPI)
# ============================================
# Python cache
backend/__pycache__/
backend/.pytest_cache/
backend/.coverage
backend/htmlcov/
backend/.mypy_cache/
backend/.ruff_cache/
backend/.pytype/
backend/.tox/
backend/.benchmarks/

# Build artifacts
backend/dist/
backend/build/
backend/*.egg-info/
backend/.eggs/

# Database migrations (if using Alembic)
backend/database/migrations/versions/*.py
!backend/database/migrations/versions/__init__.py

# Logs
backend/logs/
backend/*.log

# Environment
backend/.env
backend/.venv
backend/venv/

# ============================================
# ML Models (Large Files)
# ============================================
*.pkl
*.pickle
*.h5
*.hdf5
*.joblib
*.onnx
*.tflite
*.pb
*.pth
*.pt
*.ckpt
*.safetensors
*.model
*.weights
*.bin
*.onnx
*.mar

# ML model directories
ml_models/saved_models/
ml_models/training_data/
ml_models/checkpoints/
ml_models/experiments/
ml_models/logs/
ml_models/tensorboard/

# ============================================
# Docker
# ============================================
docker/volumes/
docker/data/
docker/db-data/
docker/redis-data/
docker/.env

# Docker volumes
*.pid
*.sock
*.socket

# ============================================
# Jupyter Notebooks
# ============================================
.ipynb_checkpoints/
*.ipynb
!*.ipynb  # Uncomment if you want to track notebooks

# ============================================
# Terraform / Infrastructure
# ============================================
*.tfstate
*.tfstate.*
.terraform/
*.terraform.lock.hcl
terraform.tfvars

# ============================================
# Kubernetes
# ============================================
*.kubeconfig
*.kubeconfig.*
*.pem
*.key
*.crt
*.csr
*.p12
*.pfx

